# ─── Deep Work Configuration ───────────────────────────────────

# API Server
PORT=3001                                    # API server port
DB_PATH=./data/deep-work.db                  # SQLite database file path
UPLOADS_DIR=./data/uploads                   # Screenshot file storage directory
SEED_DEMO_DATA=false                         # Set to 'true' to seed demo data on startup

# Security (optional)
DEEP_WORK_API_KEY=                           # Set a key to require X-API-Key header on all API requests
CORS_ORIGIN=                                 # Comma-separated allowed origins (e.g. http://192.168.1.50:3000), leave empty for '*'

# Web Dashboard
NEXT_PUBLIC_API_URL=http://localhost:3001/v1  # API URL used by the web dashboard
