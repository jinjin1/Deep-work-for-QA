{
  "name": "deep-work",
  "private": true,
  "version": "0.1.0",
  "description": "AI Native QA workflow platform",
  "scripts": {
    "dev": "pnpm dev:api & pnpm dev:web & wait",
    "dev:api": "pnpm --filter @deep-work/api dev",
    "dev:web": "pnpm --filter @deep-work/web dev",
    "dev:extension": "pnpm --filter @deep-work/extension dev",
    "dev:all": "pnpm dev:api & pnpm dev:web & pnpm dev:extension & wait",
    "db:reset": "pnpm --filter @deep-work/api db:reset",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
